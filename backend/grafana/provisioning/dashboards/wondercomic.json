      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 8 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 53 },
      "id": 28,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "stories_generation_in_progress",
          "legendFormat": "In progress",
          "refId": "A"
        }
      ],
      "title": "Stories Generation In Progress",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 53 },
      "id": 29,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(story_funnel_total{status=\"started\"}[5m])) by (stage)",
          "legendFormat": "started — {{stage}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(story_funnel_total{status=\"completed\"}[5m])) by (stage)",
          "legendFormat": "completed — {{stage}}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(story_funnel_total{status=\"failed\"}[5m])) by (stage)",
          "legendFormat": "failed — {{stage}}",
          "refId": "C"
        }
      ],
