# Local-only secret for admin promotion CLI.
# Do not commit the real value.
# ADMIN_PROMOTION_SECRET=change_me_locally

# Local-only secret for backup restore CLI.
# RESTORE_BACKUP_SECRET=change_me_locally

# Required
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
SESSION_SECRET_KEY=your_session_secret_key_here

# Optional — bcrypt cost factor (4-31). Keep a higher value in production.
# BCRYPT_ROUNDS=12

# Optional — SQLite database file path (relative to the backend working directory).
# Must be the same value for both the backend and backup-worker services.
# DB_PATH=wondercomic.db

# Optional — how often the backup worker runs, in seconds (default: 86400 = 24 h).
# BACKUP_INTERVAL_SECONDS=86400

# Optional — only needed for development without docker/nginx
# VITE_API_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000

# Optional — required when enabling Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# GOOGLE_REDIRECT_URI=https://localhost:8443/api/auth/oauth/google/callback
# SESSION_COOKIE_SECURE=true

# Monitoring — Grafana admin password (required when running with Docker Compose)
GRAFANA_ADMIN_PASSWORD=change_me_in_production
