# Required
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Optional — bcrypt cost factor (4-31). Keep a higher value in production.
# BCRYPT_ROUNDS=12

# Optional — SQLite database file path (relative to the backend working directory).
# Must be the same value for both the backend and backup-worker services.
# DB_PATH=wondercomic.db

# Optional — how often the backup worker runs, in seconds (default: 86400 = 24 h).
# BACKUP_INTERVAL_SECONDS=86400

# Optional — only needed for development without docker/nginx
# VITE_API_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000

# Monitoring — Grafana admin password (required when running with Docker Compose)
GRAFANA_ADMIN_PASSWORD=change_me_in_production
